# Entra ID application settings
TENANT_ID=00000000-0000-0000-0000-000000000000
CLIENT_ID=00000000-0000-0000-0000-000000000000

# Parsedmarc image/tag
PARSEDMARC_IMAGE=ghcr.io/mkilijanek/parsedmarc:9.1.2

# Optional Graph endpoint
GRAPH_URL=https://graph.microsoft.com

# Graph mailbox identity used by token refresher
MAILBOX=alerts@example.com

# Token refresh period (seconds)
REFRESH_SECONDS=3300
