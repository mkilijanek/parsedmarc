# ============================================================
# DATABASE CONFIGURATION
# ============================================================
POSTGRES_DB=threatfeed
POSTGRES_USER=threatfeed
POSTGRES_PASSWORD=

# ============================================================
# CACHE CONFIGURATION
# ============================================================
REDIS_PASSWORD=
CACHE_TTL=300

# ============================================================
# APPLICATION CONFIGURATION
# ============================================================
SECRET_KEY=
APP_PORT=8080
WORKERS=4
LOG_LEVEL=INFO

# ============================================================
# NETWORK CONFIGURATION
# ============================================================
HTTP_PORT=80
HTTPS_PORT=7003

# ============================================================
# SSL/TLS CONFIGURATION
# ============================================================
SSL_CERT_PATH=./ssl/cert.pem
SSL_KEY_PATH=./ssl/key.pem
# SSL_CHAIN_PATH=./ssl/chain.pem

# ============================================================
# MISP INTEGRATION
# ============================================================
MISP_URL=https://misp.example.com
MISP_API_KEY=
MISP_VERIFY_SSL=false
MISP_DAYS=7

# ============================================================
# CROWDSEC INTEGRATION
# ============================================================
CROWDSEC_API_KEY=
CROWDSEC_LISTS=list1,list2,list3

# ============================================================
# BACKGROUND WORKER CONFIGURATION
# ============================================================
ENABLE_BACKGROUND_JOBS=true
UPDATE_INTERVAL=600

# ============================================================
# SECURITY CONFIGURATION
# ============================================================
ALLOWED_HOSTS=*
CORS_ORIGINS=*

# ============================================================
# OPTIONAL: PGADMIN (DEVELOPMENT ONLY)
# ============================================================
PGADMIN_EMAIL=admin@localhost
PGADMIN_PASSWORD=
PGADMIN_PORT=5050

# ============================================================
# DOCKER CONFIGURATION
# ============================================================
IMAGE_NAME=threat-feed-aggregator
IMAGE_TAG=latest
BUILD_DATE=
VCS_REF=
VERSION=dev

MALWAREBAZAAR_API_URL=
MWDB_URL=
MWDB_AUTH_KEY=
TAGS=
SINCE=
UNTIL=