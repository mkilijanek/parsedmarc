# ============================================================
# DATABASE CONFIGURATION
# ============================================================
POSTGRES_DB=threatfeed
POSTGRES_USER=threatfeed
POSTGRES_PASSWORD=
DATABASE_URL=postgresql+psycopg2://threatfeed:threatfeed@postgres:5432/threatfeed
DATABASE_READ_URL=

# ============================================================
# CACHE CONFIGURATION
# ============================================================
REDIS_PASSWORD=
REDIS_URL=redis://:redispass@redis:6379/0
CACHE_TTL=300
METRICS_AUTH_TOKEN=

# ============================================================
# APPLICATION CONFIGURATION
# ============================================================
APP_ENV=development
SECRET_KEY=
APP_PORT=8080
WORKERS=3
GUNICORN_TIMEOUT=120
LOG_LEVEL=INFO
REQUESTS_PER_SECOND_MAX=1000000
RATE_LIMITS_ENABLED=true
QUERY_RESULT_LIMIT_MAX=10000
EXPORT_RESULT_LIMIT_MAX=200000
EXPORT_ASYNC_THRESHOLD=5000
EXPORT_JOB_DIR=/tmp/ioc-export-jobs
CORRELATION_LIMIT_MAX=5000
HEALTH_CACHE_TTL=5
CORRELATION_CACHE_TTL=30
DB_POOL_SIZE=6
DB_MAX_OVERFLOW=4
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
CORRELATION_SNAPSHOT_ENABLED=true
CORRELATION_SNAPSHOT_INTERVAL=60
CORRELATION_SNAPSHOT_MIN_SOURCES=2
CORRELATION_SNAPSHOT_LIMIT=1000
CORRELATION_SNAPSHOT_TYPES=all,domain,ip,url,hash,email

# ============================================================
# NETWORK CONFIGURATION
# ============================================================
HOST_PORT=7003
HTTP_PORT=80
HTTPS_PORT=7003
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,postgres,redis
REQUESTS_CA_BUNDLE=
REQUESTS_SKIP_TLS_VERIFY=false
# Optional per-feed proxy override examples:
# FEED_PROXY_URL_MWDB=http://proxy-mwdb.local:8080
# FEED_PROXY_URL_ABUSECH=http://proxy-abusech.local:8080

# ============================================================
# SSL/TLS CONFIGURATION
# ============================================================
SSL_CERT_PATH=./ssl/cert.pem
SSL_KEY_PATH=./ssl/key.pem
# SSL_CHAIN_PATH=./ssl/chain.pem

# ============================================================
# MISP INTEGRATION
# ============================================================
MISP_URL=https://misp.example.com
MISP_API_KEY=
MISP_VERIFY_SSL=false
MISP_DAYS=7
MISP_SYNC_TIMEOUT_S=30

# ============================================================
# CROWDSEC INTEGRATION
# ============================================================
CROWDSEC_API_KEY=
CROWDSEC_LISTS=list1,list2,list3

# ============================================================
# BACKGROUND WORKER CONFIGURATION
# ============================================================
ENABLE_BACKGROUND_JOBS=true
UPDATE_INTERVAL=600

# ============================================================
# SECURITY CONFIGURATION
# ============================================================
ALLOWED_HOSTS=*
CORS_ORIGINS=*
SECURITY_ALLOW_PERMISSIVE_DEFAULTS=false

# ============================================================
# OPTIONAL: PGADMIN (DEVELOPMENT ONLY)
# ============================================================
PGADMIN_EMAIL=admin@localhost
PGADMIN_PASSWORD=
PGADMIN_PORT=5050

# ============================================================
# DOCKER CONFIGURATION
# ============================================================
IMAGE_NAME=threat-feed-aggregator
IMAGE_TAG=latest
BUILD_DATE=
VCS_REF=
VERSION=dev

MALWAREBAZAAR_API_URL=
MALWAREBAZAAR_TAGS=
MALWAREBAZAAR_LIMIT=1000
MWDB_URL=
MWDB_AUTH_KEY=
MWDB_CUSTOM_FILTER=
MWDB_TAGS=
MWDB_DAYS=30
MWDB_NO_TIME_LIMIT=false
MWDB_ORGANIZATIONS=
MWDB_LIMIT=1000
FEED_HTTP_TIMEOUT_S=30
FEED_RETRY_ATTEMPTS=4
FEED_RETRY_BASE_DELAY_S=1

ABUSECH_AUTH_KEY=

THREATFOX_ENABLED=false
THREATFOX_API_URL=https://threatfox-api.abuse.ch/api/v1/
THREATFOX_AUTH_KEY=
THREATFOX_DAYS=3
THREATFOX_LIMIT=1000

URLHAUS_ENABLED=false
URLHAUS_FEED_URL=https://urlhaus.abuse.ch/downloads/text_online/
URLHAUS_LIMIT=10000

FEODOTRACKER_ENABLED=false
FEODOTRACKER_FEED_URL=https://feodotracker.abuse.ch/downloads/ipblocklist.txt
FEODOTRACKER_LIMIT=10000

YARAIFY_ENABLED=false
YARAIFY_API_URL=https://yaraify-api.abuse.ch/api/v1/
YARAIFY_AUTH_KEY=
YARAIFY_IDENTIFIER=
YARAIFY_LOOKUP_HASHES=
YARAIFY_TASK_STATUS=processed
YARAIFY_LIMIT=250

HUNTING_FPLIST_ENABLED=false
HUNTING_API_URL=https://hunting-api.abuse.ch/api/v1/
HUNTING_AUTH_KEY=
HUNTING_FPLIST_FORMAT=csv
HUNTING_FPLIST_LIMIT=10000
ABUSECH_TIMEOUT_S=30
ABUSECH_RETRY_ATTEMPTS=4
ABUSECH_RETRY_BASE_DELAY_S=1
ABUSECH_CIRCUIT_FAIL_THRESHOLD=3
ABUSECH_CIRCUIT_COOLDOWN_S=300
ADMIN_DANGEROUS_OPS=false
ADMIN_API_TOKEN=
INSTANCE_NAME=ioc-service
TAGS=
SINCE=
UNTIL=
